generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id                String                   @id @default(uuid())
  name              String
  slug              String                   @unique
  active            Boolean                  @default(true)
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt
  language          String                   @default("es")
  audits            AuditLog[]
  campaigns         Campaign[]
  commands          Command[]
  devices           Device[]
  interactions      Interaction[]
  leads             Lead[]
  recordings        Recording[]
  surveys           Survey[]
  moduleAssignments TenantModuleAssignment[]
  suiteAssignments  TenantSuiteAssignment[]
  users             User[]

  @@map("tenants")
}

model User {
  id              String        @id @default(uuid())
  email           String        @unique
  password        String
  fullName        String
  role            UserRole
  tenantId        String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  audits          AuditLog[]
  assignedDevices Device[]
  interactions    Interaction[]
  tenant          Tenant        @relation(fields: [tenantId], references: [id])

  @@index([tenantId], map: "users_tenantId_fkey")
  @@map("users")
}

model Device {
  id           String             @id @default(uuid())
  androidId    String             @unique
  name         String
  status       DeviceStatus       @default(OFFLINE)
  capabilities Json?
  tenantId     String
  operatorId   String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  executions   CommandExecution[]
  operator     User?              @relation(fields: [operatorId], references: [id])
  tenant       Tenant             @relation(fields: [tenantId], references: [id])
  interactions Interaction[]

  @@index([operatorId], map: "devices_operatorId_fkey")
  @@index([tenantId], map: "devices_tenantId_fkey")
  @@map("devices")
}

model Command {
  id         String             @id @default(uuid())
  type       CommandType
  action     String
  payload    Json?
  tenantId   String
  createdAt  DateTime           @default(now())
  executions CommandExecution[]
  tenant     Tenant             @relation(fields: [tenantId], references: [id])

  @@index([tenantId], map: "commands_tenantId_fkey")
  @@map("commands")
}

model CommandExecution {
  id        String          @id @default(uuid())
  status    ExecutionStatus @default(PENDING)
  result    Json?
  commandId String
  deviceId  String
  updatedAt DateTime        @updatedAt
  command   Command         @relation(fields: [commandId], references: [id])
  device    Device          @relation(fields: [deviceId], references: [id])

  @@index([commandId], map: "command_executions_commandId_fkey")
  @@index([deviceId], map: "command_executions_deviceId_fkey")
  @@map("command_executions")
}

model AuditLog {
  id        String   @id @default(uuid())
  action    String
  resource  String
  details   Json?
  actorId   String?
  tenantId  String
  timestamp DateTime @default(now())
  actor     User?    @relation(fields: [actorId], references: [id])
  tenant    Tenant   @relation(fields: [tenantId], references: [id])

  @@index([actorId], map: "audit_logs_actorId_fkey")
  @@index([tenantId], map: "audit_logs_tenantId_fkey")
  @@map("audit_logs")
}

model SuiteRegistry {
  id               String                  @id
  name             String
  description      String
  isActive         Boolean                 @default(true)
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
  modules          ModuleRegistry[]
  suiteAssignments TenantSuiteAssignment[]

  @@map("suite_registries")
}

model ModuleRegistry {
  id                String                   @id
  suiteId           String
  name              String
  description       String
  isActive          Boolean                  @default(true)
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt
  suite             SuiteRegistry            @relation(fields: [suiteId], references: [id])
  moduleAssignments TenantModuleAssignment[]

  @@index([suiteId], map: "module_registries_suiteId_fkey")
  @@map("module_registries")
}

model TenantSuiteAssignment {
  id         String        @id @default(uuid())
  tenantId   String
  suiteId    String
  licenseKey String        @unique
  expiresAt  DateTime
  createdAt  DateTime      @default(now())
  suite      SuiteRegistry @relation(fields: [suiteId], references: [id])
  tenant     Tenant        @relation(fields: [tenantId], references: [id])

  @@index([suiteId], map: "tenant_suite_assignments_suiteId_fkey")
  @@index([tenantId], map: "tenant_suite_assignments_tenantId_fkey")
  @@map("tenant_suite_assignments")
}

model TenantModuleAssignment {
  id        String         @id @default(uuid())
  tenantId  String
  moduleId  String
  isActive  Boolean        @default(true)
  createdAt DateTime       @default(now())
  module    ModuleRegistry @relation(fields: [moduleId], references: [id])
  tenant    Tenant         @relation(fields: [tenantId], references: [id])

  @@index([moduleId], map: "tenant_module_assignments_moduleId_fkey")
  @@index([tenantId], map: "tenant_module_assignments_tenantId_fkey")
  @@map("tenant_module_assignments")
}

model Campaign {
  id                String        @id @default(uuid())
  name              String
  description       String?
  status            String        @default("DRAFT")
  tenantId          String
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  externalSurveyUrl String?
  surveyType        String        @default("INTERNAL")
  cooldownDays      Int           @default(30)
  tenant            Tenant        @relation(fields: [tenantId], references: [id])
  interactions      Interaction[]
  leads             Lead[]
  surveys           Survey[]

  @@index([tenantId], map: "campaigns_tenantId_fkey")
  @@map("campaigns")
}

model Survey {
  id           String        @id @default(uuid())
  title        String
  schema       Json
  isActive     Boolean       @default(true)
  tenantId     String
  campaignId   String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  interactions Interaction[]
  campaign     Campaign      @relation(fields: [campaignId], references: [id])
  tenant       Tenant        @relation(fields: [tenantId], references: [id])

  @@index([campaignId], map: "surveys_campaignId_fkey")
  @@index([tenantId], map: "surveys_tenantId_fkey")
  @@map("surveys")
}

model Lead {
  id           String        @id @default(uuid())
  phone        String
  name         String
  status       String        @default("NEW")
  metadata     Json?
  tenantId     String
  campaignId   String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  lastCalledAt DateTime?
  interactions Interaction[]
  campaign     Campaign      @relation(fields: [campaignId], references: [id])
  tenant       Tenant        @relation(fields: [tenantId], references: [id])

  @@index([campaignId], map: "leads_campaignId_fkey")
  @@index([tenantId], map: "leads_tenantId_fkey")
  @@map("leads")
}

model Interaction {
  id             String      @id @default(uuid())
  status         String      @default("PENDING")
  surveyResponse Json?
  tenantId       String
  campaignId     String
  leadId         String
  surveyId       String?
  agentId        String?
  deviceId       String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  agent          User?       @relation(fields: [agentId], references: [id])
  campaign       Campaign    @relation(fields: [campaignId], references: [id])
  device         Device?     @relation(fields: [deviceId], references: [id])
  lead           Lead        @relation(fields: [leadId], references: [id])
  survey         Survey?     @relation(fields: [surveyId], references: [id])
  tenant         Tenant      @relation(fields: [tenantId], references: [id])
  recordings     Recording[]

  @@index([agentId], map: "interactions_agentId_fkey")
  @@index([campaignId], map: "interactions_campaignId_fkey")
  @@index([deviceId], map: "interactions_deviceId_fkey")
  @@index([leadId], map: "interactions_leadId_fkey")
  @@index([surveyId], map: "interactions_surveyId_fkey")
  @@index([tenantId], map: "interactions_tenantId_fkey")
  @@map("interactions")
}

model Recording {
  id            String      @id @default(uuid())
  fileUrl       String
  duration      Int
  fileSize      Int
  encrypted     Boolean     @default(true)
  tenantId      String
  interactionId String
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  interaction   Interaction @relation(fields: [interactionId], references: [id])
  tenant        Tenant      @relation(fields: [tenantId], references: [id])

  @@index([interactionId], map: "recordings_interactionId_fkey")
  @@index([tenantId], map: "recordings_tenantId_fkey")
  @@map("recordings")
}

enum UserRole {
  ADMIN
  SUPERVISOR
  OPERATOR
  SYSTEM
  TENANT_ADMIN
  AGENT
  QA
}

enum DeviceStatus {
  ONLINE
  OFFLINE
  BUSY
  ERROR
}

enum CommandType {
  BROADCAST
  UNICAST
}

enum ExecutionStatus {
  PENDING
  SENT
  DELIVERED
  EXECUTED
  FAILED
}
